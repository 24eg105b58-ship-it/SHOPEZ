PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/shopez
JWT_SECRET=shopez_jwt_secret_key_123456

# Razorpay credentials (leave blank to run in simulated/mock mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary credentials (leave blank to use local server filesystem storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP Email server configurations (leave blank to simulate and output to console)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_SECURE=false
EMAIL_FROM="SHOPEZ Support" <support@shopez.com>
